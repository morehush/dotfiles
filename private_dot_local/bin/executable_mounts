#!/bin/bash

auth="-o credentials=$HOME/.creds,uid=1000"

sudo mkdir -p $HOME/remote/g/others $HOME/remote/tv $HOME/remote/movies

sudo mount -t cifs //omv/others $HOME/remote/g/others $auth
sudo mount -t cifs //omv/tv $HOME/remote/g/tv $auth
sudo mount -t cifs //omv/movies $HOME/remote/g/movies $auth
